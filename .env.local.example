# ── 카카오맵 JavaScript 키 ────────────────────────────────────────
# 발급: https://developers.kakao.com/console/app
# 1. 카카오 계정 로그인 → "내 애플리케이션" → "애플리케이션 추가하기"
# 2. 만든 앱 → "앱 키" 메뉴에서 "JavaScript 키" 복사
# 3. "플랫폼" → "Web 플랫폼 등록" → 사이트 도메인 추가:
#    - http://localhost:3000
#    - https://your-vercel-domain.vercel.app
NEXT_PUBLIC_KAKAO_MAP_KEY=여기에_본인_JavaScript_키_붙여넣기

# ── Supabase ──────────────────────────────────────────────────────
# 발급: https://supabase.com/dashboard → 프로젝트 → Settings → API
# Project URL과 Publishable key 복사 (Secret key는 절대 사용 X)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxx
